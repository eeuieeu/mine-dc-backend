# ============================================================
# 공공데이터포털 (data.go.kr) 서비스키
# 회원가입 후 아래 3개 API에 각각 "활용신청" 필요 (승인까지 보통 1일 내외)
#   1) 기상청_단기예보 조회서비스
#      https://www.data.go.kr/data/15084084/openapi.do
#   2) 한국광해광업공단_전국 폐광산 위치 정보
#      https://www.data.go.kr/data/15117195/fileData.do
# 두 서비스 모두 공공데이터포털에서 발급되는 동일한 형태의 키를 쓰지만,
# 서비스별로 "일반 인증키(Encoding)" / "(Decoding)" 두 값이 주어지니
# axios 등 코드에서 직접 쿼리스트링을 만들 때는 Decoding 키를 사용하세요.
PUBLIC_DATA_SERVICE_KEY=여기에_공공데이터포털_서비스키_입력

# ============================================================
# 카카오(Kakao) 로컬 API - REST API 키
# https://developers.kakao.com 가입 → 애플리케이션 추가
# 앱 설정 > 앱 키 > "REST API 키" 복사
# ⚠ 필수: 앱 설정 > 카카오맵 > 사용 설정을 ON으로 바꿔야 작동합니다
#    (2024-12-01 이후 신규 앱에 적용되는 정책)
# 브이월드 대신 이걸 쓰는 이유: 브이월드는 클라우드 서버(Render 등)에서
# 오는 요청을 IDC 대역이라는 이유로 차단해서, 배포 환경에서는 작동하지
# 않습니다. 카카오는 이런 제한이 없습니다.
KAKAO_REST_API_KEY=여기에_카카오_REST_API_키_입력

# ============================================================
# 서버 설정
PORT=4000
CACHE_TTL_SECONDS=3600
